        RowBox[{"dXer", " ", 
         RowBox[{"D", "[", 
          RowBox[{"expr", ",", "X"}], "]"}]}], "+", 
        RowBox[{"D", "[", 
         RowBox[{"expr", ",", "r"}], "]"}]}]}]}], " ", 
     RowBox[{"(*", 
      RowBox[{"Apply", " ", "chain", " ", "rule"}], "*)"}], "]"}]}], "\n", 
   RowBox[{
    RowBox[{"customDerivativer", "[", 
     RowBox[{"expr_", ",", 
