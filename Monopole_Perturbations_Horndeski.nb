       InterpretationBox[
        StyleBox["\[Psi]",
         ShowAutoStyles->False,
         AutoSpacing->False],
        $CellContext`\[Psi],
        Editable->False], "\[Prime]",
       MultilineFunction->None], "[", "r", "]"}], ">", "0"}], ",", " ", 
    RowBox[{
     RowBox[{"Z", "[", "X", "]"}], "<", 
     RowBox[{
      RowBox[{"0", "  ", "so", " ", 
       SuperscriptBox["q", "2"]}], "-", 
      RowBox[{"2", " ", "X", " ", 
       RowBox[{
        InterpretationBox[
         StyleBox["A",
          ShowAutoStyles->False,
          AutoSpacing->False],
         $CellContext`A,
         Editable->False], "[", "r", "]"}]}]}], " ", ">", "0", " "}]}]}]], 
  "Text",
