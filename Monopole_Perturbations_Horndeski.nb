      RowBox[{"2.", " ", "Use", " ", "IMMEDIATE", " ", "ASSIGNMENT", " ", 
       RowBox[{"(", "=", ")"}], " ", "to", " ", "store", " ", "the", " ", 
       "result", " ", "globally"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"nradialcoordstealth", "[", "r_", "]"}], "=", "tempn"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<The new radial coordinate is defined via n(r)= \>\"", 
         SqrtBox[
          FractionBox[
           RowBox[{"b02", "[", "r", "]"}], 
           RowBox[{"b20", "[", "r", "]"}]]]}], "}"}], "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "usualAssumptionsStealth"}]}], "]"}], 
        "&"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<The normalization factor a the mastervariable is \
given by: \>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"b01", "[", "r", "]"}], " ", 
            RowBox[{"b20", "[", "r", "]"}]}], "-", 
           RowBox[{
            RowBox[{"b20", "[", "r", "]"}], " ", 
            RowBox[{"b02customr", "[", "r", "]"}]}], "+", 
           RowBox[{
            RowBox[{"b02", "[", "r", "]"}], " ", 
            RowBox[{"b20customr", "[", "r", "]"}]}]}], 
          RowBox[{"4", " ", 
           RowBox[{"b02", "[", "r", "]"}], " ", 
           RowBox[{"b20", "[", "r", "]"}]}]]}], "/.", "ArulenSchw"}], "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "usualAssumptionsStealth"}]}], "]"}], 
        "&"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalChi]", "[", "rs_", "]"}], ":=", 
      RowBox[{"\[CapitalPsi]", "[", "rs", "]"}]}], ";", "\[IndentingNewLine]",
      " ", 
     RowBox[{"Collect", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"EQcustomfromEOM", "//.", "psitosquareX"}], "/.", 
         RowBox[{"X", "->", 
          RowBox[{"Xe", "[", "r", "]"}]}]}], "/.", "ArulenSchw"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", 
         RowBox[{
          RowBox[{"\[CapitalPsi]", "''"}], "[", "rs", "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"FullSimplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "usualAssumptionsStealth"}]}], "]"}], 
        "&"}]}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
