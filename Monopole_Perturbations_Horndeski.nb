      RowBox[{"b01customr", "[", "r_", "]"}], ":=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"customDerivativer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"b01", "[", "r", "]"}], "/.", "bigbracket"}], ",", "r"}], 
          "]"}], "//.", "rulesbackground"}], "/.", "Abackroundrule"}], "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], 
        "&"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"b02custom2r", "[", "r_", "]"}], ":=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"customDerivativer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"b02customr", "[", "r", "]"}], "/.", "bigbracket"}], ",", 
           "r"}], "]"}], "//.", "rulesbackground"}], "/.", "Abackroundrule"}],
        "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], 
        "&"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"b20customr", "[", "r_", "]"}], ":=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"customDerivativer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"b20", "[", "r", "]"}], "/.", "bigbracket"}], ",", "r"}], 
          "]"}], "//.", "rulesbackground"}], "/.", "Abackroundrule"}], "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], 
        "&"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"b20custom2r", "[", "r_", "]"}], ":=", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"customDerivativer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"b20customr", "[", "r", "]"}], "/.", "bigbracket"}], ",", 
           "r"}], "]"}], "//.", "rulesbackground"}], "/.", "Abackroundrule"}],
        "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], 
        "&"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<The new radial coordinate is defined via n(r)= \>\"", 
         SqrtBox[
          FractionBox[
           RowBox[{"b02", "[", "r", "]"}], 
           RowBox[{"b20", "[", "r", "]"}]]]}], "}"}], "//", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], "&"}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalChi]", "[", "rs_", "]"}], ":=", 
      RowBox[{"\[CapitalPsi]", "[", "rs", "]"}]}], ";", "\[IndentingNewLine]",
      " ", 
     RowBox[{"Collect", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"EQcustomfromEOM", "/.", "Abackroundrule"}], "//.", 
        "rulesbackground"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Omega]", ",", 
         RowBox[{
          SuperscriptBox["\[CapitalPsi]", "\[Prime]\[Prime]",
           MultilineFunction->None], "[", "rs", "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Simplify", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], "&"}]}], 
      "]"}]}]}], "]"}]}]], "Input",
