            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "6"]], "-", 
          FractionBox[
           RowBox[{"15", 
            SuperscriptBox[
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"Xe", "[", "r", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"r", ",", "2"}], "}"}]}], "]"}], "3"]}], 
           SuperscriptBox[
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "7"]]}], ")"}], "*", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "func", "]"}], "[", "r",
          "]"}]}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "3", "]"}], "[", "func_", "]"}], "[", "X", 
       "]"}], ":>", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
