Cell["\<\
Thes rules customDerivativeX and customDerivativer help us to take into \
account the dependency of X on r.\
\>", "Text",
 CellChangeTimes->{{3.989572957536296*^9, 
  3.989572980445376*^9}},ExpressionUUID->"fbf466b5-402c-4b5f-9a44-\
111bf756462d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "custom", " ", "derivative", " ", "rule"}], 
   "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"customDerivativeX", "[", 
     RowBox[{"expr_", ",", "X_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", "dXer", "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"dXer", "=", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"Xe", "[", "r", "]"}], ",", "r"}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{"Compute", " ", 
         RowBox[{"dX_e", "/", "dr"}]}], "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "/", "dXer"}], ")"}], "*", 
         RowBox[{"D", "[", 
          RowBox[{"expr", ",", "r"}], "]"}]}], "+", 
        RowBox[{"D", "[", 
         RowBox[{"expr", ",", "X"}], "]"}]}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"customDerivativeX", "[", 
     RowBox[{"expr_", ",", 
      RowBox[{"{", 
       RowBox[{"X_Symbol", ",", 
        RowBox[{"n_Integer", "?", "Positive"}]}], "}"}]}], "]"}], ":=", 
    RowBox[{"Nest", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"customDerivativeX", "[", 
        RowBox[{"#", ",", "X"}], "]"}], "&"}], ",", "expr", ",", "n"}], 
     "]"}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"expr", "=", " ", 
     RowBox[{"X", " ", 
      RowBox[{"F", "[", "r", "]"}]}]}], ";"}], "\n", 
   RowBox[{"customDerivativeX", "[", 
    RowBox[{"expr", ",", 
     RowBox[{"{", 
      RowBox[{"X", ",", "2"}], "}"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"%", "-", 
     RowBox[{"customDerivativeX", "[", 
      RowBox[{
       RowBox[{"customDerivativeX", "[", 
        RowBox[{"expr", ",", "X"}], "]"}], ",", "X"}], "]"}]}], "//", 
    "Simplify"}]}]}]], "Input",
 CellChangeTimes->{{3.9466161377345533`*^9, 3.94661636392794*^9}, {
  3.946617803426556*^9, 3.946617902621603*^9}, {3.9466179334002438`*^9, 
