         SuperscriptBox[
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Xe", "[", "r", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "5"]], "*", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "3", "]"}], "[", "func", "]"}], "[", "r",
          "]"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          FractionBox[
           RowBox[{"15", "*", 
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"Xe", "[", "r", "]"}], ",", 
               RowBox[{"{", 
                RowBox[{"r", ",", "2"}], "}"}]}], "]"}], "^", "2"}]}], 
           RowBox[{
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "^", "6"}]], "-", 
          FractionBox[
           RowBox[{"4", "*", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "3"}], "}"}]}], "]"}]}], 
           SuperscriptBox[
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "5"]]}], ")"}], 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "2", "]"}], "[", "func", "]"}], "[", "r",
          "]"}]}], "+", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          FractionBox[
           RowBox[{"-", 
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
