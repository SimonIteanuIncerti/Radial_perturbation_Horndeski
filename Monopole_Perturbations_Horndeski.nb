Cell[TextData[{
 "This rule replaces all the occurences of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"\[Psi]", "'"}], "2"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "e95daa82-a05d-4f82-af8a-30ecd6848d8e"],
 " by a function of X in order to simplify our equations"
}], "Text",
 CellChangeTimes->{{3.989569039467785*^9, 
  3.9895690842230186`*^9}},ExpressionUUID->"3defb3bf-61a0-4ba8-a3ee-\
3b09ab8e21fe"],

Cell[BoxData[
 RowBox[{
  RowBox[{"psisquaredtoXN12", "=", 
   RowBox[{
    RowBox[{"Block", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"B", ",", "Xe"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"B", "[", "r_", "]"}], ":=", 
        RowBox[{"A", "[", "r", "]"}]}], ";", "  ", 
       RowBox[{
        RowBox[{"Xe", "[", "r_", "]"}], ":=", 
        FractionBox[
         RowBox[{
          SuperscriptBox["q", "2"], " "}], 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["r", "2"], "+", "1"}], ")"}]}]]}], ";", "  ", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{
                SuperscriptBox[
                 InterpretationBox[
                  StyleBox["\[Psi]",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`\[Psi],
                  Editable->False], "\[Prime]",
                 MultilineFunction->None], "[", "r", "]"}], "n_"], "/;", 
              RowBox[{"n", "\[GreaterEqual]", "2"}]}], "\[RuleDelayed]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"EvenQ", "[", "n", "]"}], ",", 
               SuperscriptBox[
                RowBox[{"(", 
                 FractionBox[
                  RowBox[{
                   RowBox[{
                    RowBox[{"-", "2"}], " ", "X"}], "+", 
                   FractionBox[
                    SuperscriptBox["q", "2"], 
                    RowBox[{
                    InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "[", "r", "]"}]]}], 
                  RowBox[{"A", "[", "r", "]"}]], ")"}], 
                RowBox[{"n", "/", "2"}]], ",", 
               RowBox[{
                SuperscriptBox[
                 RowBox[{"(", 
                  FractionBox[
                   RowBox[{
                    RowBox[{
                    RowBox[{"-", "2"}], " ", "X"}], "+", 
                    FractionBox[
                    SuperscriptBox["q", "2"], 
                    RowBox[{
                    InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "[", "r", "]"}]]}], 
                   RowBox[{"A", "[", "r", "]"}]], ")"}], 
                 RowBox[{
                  FractionBox["1", "2"], " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"-", "1"}], "+", "n"}], ")"}]}]], " ", 
                RowBox[{
                 SuperscriptBox[
                  InterpretationBox[
                   StyleBox["\[Psi]",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                   $CellContext`\[Psi],
                   Editable->False], "\[Prime]",
                  MultilineFunction->None], "[", "r", "]"}]}]}], "]"}]}], ",", 
            RowBox[{
             RowBox[{
              SuperscriptBox[
               InterpretationBox[
                StyleBox["\[Psi]",
                 ShowAutoStyles->False,
                 AutoSpacing->False],
                $CellContext`\[Psi],
                Editable->False], "\[Prime]\[Prime]",
               MultilineFunction->None], "[", "r", "]"}], "\[Rule]", 
             FractionBox[
              RowBox[{
               RowBox[{"-", 
                FractionBox[
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    FractionBox[
                    SuperscriptBox["q", "2"], 
                    RowBox[{
                    InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "[", "r", "]"}]], "-", 
                    RowBox[{"2", " ", 
                    RowBox[{"Xe", "[", "r", "]"}]}]}], ")"}], " ", 
                  RowBox[{
                   SuperscriptBox["A", "\[Prime]",
                    MultilineFunction->None], "[", "r", "]"}]}], 
                 SuperscriptBox[
                  RowBox[{"A", "[", "r", "]"}], "2"]]}], "+", 
               FractionBox[
                RowBox[{
                 RowBox[{"-", 
                  FractionBox[
                   RowBox[{
                    SuperscriptBox["q", "2"], " ", 
                    RowBox[{
                    SuperscriptBox[
                    InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "\[Prime]",
                    MultilineFunction->None], "[", "r", "]"}]}], 
                   SuperscriptBox[
                    RowBox[{
                    InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "[", "r", "]"}], "2"]]}], "-", 
                 RowBox[{"2", " ", 
                  RowBox[{
                   SuperscriptBox["Xe", "\[Prime]",
                    MultilineFunction->None], "[", "r", "]"}]}]}], 
                RowBox[{"A", "[", "r", "]"}]]}], 
              RowBox[{"2", " ", 
               RowBox[{
                SuperscriptBox[
                 InterpretationBox[
                  StyleBox["\[Psi]",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`\[Psi],
                  Editable->False], "\[Prime]",
                 MultilineFunction->None], "[", "r", "]"}]}]]}], ",", 
            RowBox[{
             FractionBox["1", 
              SuperscriptBox[
               RowBox[{
                SuperscriptBox[
                 InterpretationBox[
                  StyleBox["\[Psi]",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`\[Psi],
                  Editable->False], "\[Prime]",
                 MultilineFunction->None], "[", "r", "]"}], "2"]], "\[Rule]", 
             
             FractionBox[
              RowBox[{"A", "[", "r", "]"}], 
              RowBox[{
               RowBox[{
                RowBox[{"-", "2"}], " ", "X"}], "+", 
               FractionBox[
                SuperscriptBox["q", "2"], 
                RowBox[{
                 InterpretationBox[
                  StyleBox["A",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`A,
                  Editable->False], "[", "r", "]"}]]}]]}], ",", 
            RowBox[{
             FractionBox["1", 
              SuperscriptBox[
               RowBox[{
                SuperscriptBox[
                 InterpretationBox[
                  StyleBox["\[Psi]",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`\[Psi],
                  Editable->False], "\[Prime]",
                 MultilineFunction->None], "[", "r", "]"}], "3"]], "\[Rule]", 
             
             FractionBox[
              RowBox[{"A", "[", "r", "]"}], 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "2"}], " ", "X"}], "+", 
                 FractionBox[
                  SuperscriptBox["q", "2"], 
                  RowBox[{
                   InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "[", "r", "]"}]]}], ")"}], " ", 
               RowBox[{
                SuperscriptBox[
                 InterpretationBox[
                  StyleBox["\[Psi]",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`\[Psi],
                  Editable->False], "\[Prime]",
                 MultilineFunction->None], "[", "r", "]"}]}]]}], ",", 
            RowBox[{
             FractionBox["1", 
              SuperscriptBox[
               RowBox[{
                SuperscriptBox[
                 InterpretationBox[
                  StyleBox["\[Psi]",
                   ShowAutoStyles->False,
                   AutoSpacing->False],
                  $CellContext`\[Psi],
                  Editable->False], "\[Prime]",
                 MultilineFunction->None], "[", "r", "]"}], "4"]], "\[Rule]", 
             
             FractionBox[
              SuperscriptBox[
               RowBox[{
                InterpretationBox[
                 StyleBox["B",
                  ShowAutoStyles->False,
                  AutoSpacing->False],
                 $CellContext`B,
                 Editable->False], "[", "r", "]"}], "2"], 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"-", "2"}], " ", "X"}], "+", 
                 FractionBox[
                  SuperscriptBox["q", "2"], 
                  RowBox[{
                   InterpretationBox[
                    StyleBox["A",
                    ShowAutoStyles->False,
                    AutoSpacing->False],
                    $CellContext`A,
                    Editable->False], "[", "r", "]"}]]}], ")"}], "2"]]}]}], 
           "}"}], "/.", "bigbracket"}], "/.", 
         RowBox[{"X", "->", 
          RowBox[{"Xe", "[", "r", "]"}]}]}], "/.", "ArulenSchw"}]}]}], "]"}], 
    "//", "FullSimplify"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.981629351227552*^9, 3.98162936022899*^9}, 
   3.981631520152009*^9, {3.981631555130294*^9, 3.981631560662113*^9}, {
