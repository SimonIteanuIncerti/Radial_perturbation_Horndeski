              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "5"]], "+", 
          FractionBox[
           RowBox[{"10", "*", 
            RowBox[{"D", "[", 
