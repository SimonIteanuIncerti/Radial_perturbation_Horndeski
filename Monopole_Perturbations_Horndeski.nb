          FractionBox[
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Xe", "[", "r", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"r", ",", "3"}], "}"}]}], "]"}], 
           SuperscriptBox[
            RowBox[{"D", "[", 
             RowBox[{
              RowBox[{"Xe", "[", "r", "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "4"]]}], ")"}], "*", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "func", "]"}], "[", "r",
          "]"}]}]}]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "2", "]"}], "[", "func_", "]"}], "[", "X", 
       "]"}], ":>", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         FractionBox["1", 
          SuperscriptBox[
           RowBox[{"D", "[", 
            RowBox[{
             RowBox[{"Xe", "[", "r", "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "2"]], ")"}], "*", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "2", "]"}], "[", "func", "]"}], "[", "r",
          "]"}]}], "-", 
       RowBox[{
        FractionBox[
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{"Xe", "[", "r", "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"r", ",", "2"}], "}"}]}], "]"}], 
         SuperscriptBox[
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"Xe", "[", "r", "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"r", ",", "1"}], "}"}]}], "]"}], "3"]], "*", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "func", "]"}], "[", "r",
          "]"}]}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "1", "]"}], "[", "func_", "]"}], "[", "X", 
       "]"}], "\[RuleDelayed]", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "func", "]"}], "[", "r", 
        "]"}], "*", 
       FractionBox["1", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"Xe", "[", "r", "]"}], ",", 
