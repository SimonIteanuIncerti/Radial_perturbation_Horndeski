Cell[BoxData[{
 RowBox[{
  RowBox[{"ruleradialcoord", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "2", "]"}], "[", "\[CapitalChi]", "]"}], "[",
        "r", "]"}], "->", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          FractionBox["1", 
           RowBox[{"nradialcoord", "[", "r", "]"}]], ",", "r"}], "]"}], 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "\[CapitalChi]", "]"}], 
         "[", "rs", "]"}]}], "+", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox[
          RowBox[{"nradialcoord", "[", "r", "]"}], "2"]], 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "2", "]"}], "[", "\[CapitalChi]", "]"}], 
         "[", "rs", "]"}]}]}]}], ",", "  ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", "1", "]"}], "[", "\[CapitalChi]", "]"}], "[",
        "r", "]"}], "->", 
      RowBox[{
       FractionBox["1", 
        RowBox[{"nradialcoord", "[", "r", "]"}]], 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "1", "]"}], "[", "\[CapitalChi]", "]"}], "[",
         "rs", "]"}]}]}], ",", 
