Cell[BoxData[
 RowBox[{
  RowBox[{"ToFourier", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"n_", ",", "m_"}], "]"}], "[", "func_", "]"}], "[", 
       RowBox[{
        RowBox[{"t", "[", "]"}], ",", 
        RowBox[{"r", "[", "]"}]}], "]"}], ":>", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "\[Omega]", " ", 
         RowBox[{"t", "[", "]"}]}], "]"}], " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "I"}], " ", "\[Omega]"}], ")"}], "^", "n"}], " ", 
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", "m", "]"}], "[", "func", "]"}], "[", 
        RowBox[{"r", "[", "]"}], "]"}]}]}], ",", 
     RowBox[{
      RowBox[{"func_", "[", 
       RowBox[{
        RowBox[{"t", "[", "]"}], ",", 
        RowBox[{"r", "[", "]"}]}], "]"}], ":>", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "\[Omega]", " ", 
         RowBox[{"t", "[", "]"}]}], "]"}], " ", 
       RowBox[{"func", "[", 
        RowBox[{"r", "[", "]"}], "]"}]}]}]}], "}"}]}], ";"}]], "Input",
