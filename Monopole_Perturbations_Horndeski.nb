Cell["\<\
We can then reabsorb the time derivative by a time redefinition:\
\>", "Text",
 CellChangeTimes->{{3.989569200516438*^9, 
  3.989569218289673*^9}},ExpressionUUID->"4ba2e85c-8ec4-40e7-a62a-\
a76ce1827086"],

Cell[BoxData[{
 RowBox[{"TimeRedefp12", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Coefficient", "[", 
        RowBox[{
         RowBox[{"EOMH2p12", "/.", "Ruletstar"}], ",", 
         RowBox[{
          SuperscriptBox[
           InterpretationBox[
            StyleBox[
             SubscriptBox["H", "2"],
             ShowAutoStyles->False,
             AutoSpacing->False],
            $CellContext`H2,
            Editable->False], 
           TagBox[
            RowBox[{"(", 
             RowBox[{"1", ",", "0"}], ")"}],
            Derivative],
           MultilineFunction->None], "[", 
          RowBox[{"t", ",", "r"}], "]"}]}], "]"}], "==", "0"}], ",", 
      RowBox[{"W", "[", "r", "]"}]}], "]"}], "//", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{"#", ",", 
       RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], "&"}]}], "//",
    "Flatten"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"EOMH2p12", "/.", "Ruletstar"}], "/.", "%"}], "//.", 
    "psisquaredtoXN12"}], "//", 
   RowBox[{
    RowBox[{"Simplify", "[", 
     RowBox[{"#", ",", 
      RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], "&"}]}], "//",
   "First"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"DSolve", "[", 
   RowBox[{
    RowBox[{"%", "==", "0"}], ",", 
    RowBox[{"H2", "[", 
     RowBox[{"t", ",", "r"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "//", "Flatten"}], "\[IndentingNewLine]", 
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", "H2", "}"}], ",", 
   RowBox[{
    RowBox[{
     RowBox[{"H2", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], ":=", 
     FractionBox[
      RowBox[{
       TemplateBox[{"1"},
        "C"], "[", "t", "]"}], 
      RowBox[{"r", " ", 
       RowBox[{"A", "[", "r", "]"}]}]]}], ";", 
    RowBox[{
     RowBox[{"%%", "/.", "ArulenSchw"}], "//", "Simplify"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c1toH2n12", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        TemplateBox[{"1"},
         "C"], "''"}], "[", "t", "]"}], "->", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"r", " ", 
         RowBox[{"A", "[", "r", "]"}], 
         RowBox[{"H2", "[", 
          RowBox[{"t", ",", "r"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "2"}], "}"}]}], "]"}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        TemplateBox[{"1"},
         "C"], "\[Prime]",
        MultilineFunction->None], "[", "t", "]"}], "->", 
      RowBox[{"D", "[", 
       RowBox[{
        RowBox[{"r", " ", 
         RowBox[{"A", "[", "r", "]"}], 
         RowBox[{"H2", "[", 
          RowBox[{"t", ",", "r"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "1"}], "}"}]}], "]"}]}], ",", 
     RowBox[{
      RowBox[{
       TemplateBox[{"1"},
        "C"], "[", "t", "]"}], "->", 
      RowBox[{"r", " ", 
       RowBox[{"A", "[", "r", "]"}], 
       RowBox[{"H2", "[", 
        RowBox[{"t", ",", "r"}], "]"}]}]}]}], "}"}]}], ";"}]}], "Input",
