        SuperscriptBox["r", "2"]}], ")"}], "2"], "-", "\[Xi]"}], ">", "0"}], ",", 
   RowBox[{
    RowBox[{"1", "-", 
     FractionBox[
      RowBox[{" ", 
       RowBox[{
        RowBox[{"(", 
