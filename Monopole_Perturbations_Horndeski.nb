Cell[BoxData[{
 RowBox[{
  RowBox[{"toxi", "=", 
   RowBox[{"{", 
    RowBox[{
     InterpretationBox[
      StyleBox["\[Alpha]",
       ShowAutoStyles->False,
       AutoSpacing->False],
      $CellContext`\[Alpha],
      Editable->False], " ", "\[Rule]", 
     RowBox[{"(", 
      FractionBox[
       RowBox[{"4", " ", "\[Xi]"}], 
       RowBox[{"3", 
        SuperscriptBox["q", "4"]}]], ")"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"AlgebraicEqX", ",", "AEq", ",", "ZEq"}], "}"}], "/.", 
     "RuleFromXtor"}], ")"}], "//", "Simplify"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "Z", ",", "G4", ",", "Xe", ",", "A", ",", "G2", ",", "B", ",", 
     "\[Gamma]"}], "}"}], ",", 
   RowBox[{
    RowBox[{"\[Gamma]", ":=", "1"}], ";", 
    RowBox[{
     RowBox[{"Z", "[", "r_", "]"}], ":=", 
     RowBox[{"-", 
      SqrtBox[
       RowBox[{"1", "-", 
        FractionBox["\[Xi]", 
         SuperscriptBox[
