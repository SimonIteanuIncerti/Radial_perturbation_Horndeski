Cell[BoxData[
 RowBox[{"EOMH2p12", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"EOMsHorndeskiMonop12", "[", 
          RowBox[{"[", "1", "]"}], "]"}], "+", 
         RowBox[{"aa", " ", 
          RowBox[{"EOMsHorndeskiMonop12", "[", 
           RowBox[{"[", "2", "]"}], "]"}]}]}], "/.", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Coefficient", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"EOMsHorndeskiMonop12", "[", 
               RowBox[{"[", "1", "]"}], "]"}], "+", 
              RowBox[{"aa", " ", 
               RowBox[{"EOMsHorndeskiMonop12", "[", 
                RowBox[{"[", "2", "]"}], "]"}]}]}], ",", 
             RowBox[{"H0", "[", 
              RowBox[{"t", ",", "r"}], "]"}]}], "]"}], "==", "0"}], ",", 
          "aa"}], "]"}]}], "//.", "psisquaredtoXN12"}], "//", 
      RowBox[{
       RowBox[{"Simplify", "[", 
        RowBox[{"#", ",", 
         RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], "&"}]}], 
     ")"}], "//.", "psisquaredtoXN12"}], "//", 
   RowBox[{
    RowBox[{"Simplify", "[", 
     RowBox[{"#", ",", 
      RowBox[{"Assumptions", "->", "AssumptionsApos"}]}], "]"}], 
    "&"}]}]}]], "Input",
