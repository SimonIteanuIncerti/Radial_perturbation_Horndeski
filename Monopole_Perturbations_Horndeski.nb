Cell[TextData[{
 "Considering the branch ",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{
    RowBox[{
     RowBox[{
      InterpretationBox[
       StyleBox["A",
        ShowAutoStyles->False,
        AutoSpacing->False],
       $CellContext`A,
       Editable->False], "[", "r", "]"}], ">", "0"}], ",", 
    RowBox[{
