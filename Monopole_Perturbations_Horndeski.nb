Cell[BoxData[{
 RowBox[{"EOMsHorndeskiMonop12", "=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "B", ",", "A", ",", "\[Psi]", ",", "G2", ",", "G4", ",", "Xe", ",", "q", 
      ",", "GG", ",", "\[Lambda]", ",", "BB", ",", "Z", ",", "\[CapitalPhi]", 
      ",", "Y", ",", "KK"}], "}"}], ",", 
    RowBox[{
     RowBox[{
      RowBox[{"Y", "[", 
       RowBox[{"l_", ",", "m_", ",", "\[Theta]_", ",", "\[CurlyPhi]_"}], 
       "]"}], ":=", "1"}], ";", " ", 
     RowBox[{
      RowBox[{"KK", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":=", "0"}], ";", 
     RowBox[{
      RowBox[{"\[CapitalPhi]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":=", "0"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"G4", "[", "X_", "]"}], ":=", 
      RowBox[{"1", "-", 
       RowBox[{"\[Alpha]", 
        SqrtBox["X"]}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"G2", "[", "X_", "]"}], ":=", 
      RowBox[{
       FractionBox[
        RowBox[{
         RowBox[{"-", "2"}], "\[Alpha]"}], 
        SuperscriptBox["\[Lambda]", "2"]], 
       SqrtBox["X"]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", "r_", "]"}], ":=", 
      RowBox[{"A", "[", "r", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Lambda]", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Xe", "[", "r_", "]"}], ":=", 
      FractionBox[
       RowBox[{
        SuperscriptBox["q", "2"], " ", 
        SuperscriptBox[
         InterpretationBox[
          StyleBox["\[Lambda]",
           ShowAutoStyles->False,
           AutoSpacing->False],
          $CellContext`\[Lambda],
          Editable->False], "2"]}], 
       RowBox[{"2", " ", 
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["r", "2"], "+", 
          SuperscriptBox[
           InterpretationBox[
            StyleBox["\[Lambda]",
             ShowAutoStyles->False,
             AutoSpacing->False],
            $CellContext`\[Lambda],
            Editable->False], "2"]}], ")"}]}]]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"Z", "[", "X_", "]"}], ":=", 
      RowBox[{"-", "1"}]}], ";", 
     RowBox[{"coco", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"coco", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Extract", "[", 
                RowBox[{"EOMsHorndeski", ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"{", 
                    RowBox[{"1", ",", "1"}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"1", ",", "2"}], "}"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"2", ",", "2"}], "}"}]}], "}"}]}], "]"}], "//.", 
               "psisquaredtoXN12"}], "/.", 
              RowBox[{"X", "->", 
               RowBox[{"Xe", "[", "r", "]"}]}]}], "/.", "ArulenSchw"}], "/.", 
            "bigbracket"}], ",", "AssumptionsApos"}], "]"}], "//.", 
         "psisquaredtoXN12"}], "/.", 
        RowBox[{"X", "->", 
         RowBox[{"Xe", "[", "r", "]"}]}]}], ",", "AssumptionsApos"}], 
      "]"}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"DeleteDuplicates", "@", 
    RowBox[{"Cases", "[", 
     RowBox[{"#", ",", 
      RowBox[{"F__", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "Infinity"}], "]"}]}], "&"}], "/@",
   "%"}], "\[IndentingNewLine]"}], "Input",
