Cell[TextData[{
 "By combinin two equations, one obtains an equation depending only on ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["H", 
    RowBox[{"2", " "}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "83159dcc-a94f-4899-91f3-61523152609b"],
 " and its derivatives"
}], "Text",
 CellChangeTimes->{{3.989569170834434*^9, 
  3.98956919733353*^9}},ExpressionUUID->"0c3c8568-fcd5-4f8d-8949-\
