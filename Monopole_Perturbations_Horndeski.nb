Cell["\<\
All the objects in xAct come with []. The following rules help us to remove \
the [].s\
\>", "Text",
 CellChangeTimes->{{3.989572863101156*^9, 
  3.989572941031855*^9}},ExpressionUUID->"b85b736b-25e1-42ee-810e-\
38c335c68b44"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"bracket", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"t", "[", "]"}], "->", "t"}], ",", 
     RowBox[{
      RowBox[{"r", "[", "]"}], "->", "r"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bigbracket", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"bracket", "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", 
     RowBox[{"bracket", "[", 
      RowBox[{"[", "2", "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"X", "[", "]"}], "->", "X"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Nobracket", "[", "expr_", "]"}], ":=", 
  RowBox[{"expr", "//.", " ", 
   RowBox[{
    RowBox[{"f_Symbol", "[", "]"}], ":>", "f"}]}]}]}], "Input",
 CellChangeTimes->{{3.9466156625777187`*^9, 3.94661568432703*^9}, {
   3.947051524313839*^9, 3.947051546381156*^9}, {3.947051580882341*^9, 
