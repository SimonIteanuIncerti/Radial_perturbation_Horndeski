Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Define", " ", "the", " ", "custom", " ", "derivative", " ", "rule", " ", 
    "wr", " ", "r"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"customDerivativer", "[", 
     RowBox[{"expr_", ",", "r_"}], "]"}], ":=", 
