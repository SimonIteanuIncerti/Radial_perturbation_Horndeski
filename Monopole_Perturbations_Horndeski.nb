          RowBox[{"Xe", "[", "r", "]"}], ",", "r"}], "]"}]}], ";", 
       RowBox[{"(*", 
        RowBox[{"Compute", " ", 
         RowBox[{"dX_e", "/", "dr"}]}], "*)"}], "\[IndentingNewLine]", 
