Cell["coco is just a shortcut to use Collect efficiently", "Text",
 CellChangeTimes->{{3.989486935025215*^9, 3.989486951483819*^9}, {
  3.9919964791000023`*^9, 
  3.9919964792906637`*^9}},ExpressionUUID->"74c780ab-ba8b-480a-b110-\
902dc7af11c9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"coco", "[", 
   RowBox[{"expr_", ",", 
    RowBox[{"assumptions_", ":", "True"}], ",", 
    RowBox[{"method_", ":", "Simplify"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "vars", "}"}], ",", 
    RowBox[{
     RowBox[{"vars", "=", 
      RowBox[{"DeleteDuplicates", "@", 
       RowBox[{"Cases", "[", 
        RowBox[{"expr", ",", 
         RowBox[{"F__", "[", 
          RowBox[{"t", ",", "r"}], "]"}], ",", "Infinity"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Collect", "[", 
      RowBox[{"expr", ",", "vars", ",", 
       RowBox[{
        RowBox[{"method", "[", 
         RowBox[{"#", ",", 
          RowBox[{"Assumptions", "->", "assumptions"}]}], "]"}], "&"}]}], 
      "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.98171127507953*^9, 3.9817112753904047`*^9}, 
   3.9821390261741323`*^9, {3.982139143314683*^9, 3.982139145799138*^9}, {
   3.9841271689683533`*^9, 3.984127171065063*^9}},
 CellLabel->"In[82]:=",ExpressionUUID->"80074b03-181a-4aed-b111-2d3c2b4d8c57"]
}, Closed]],

