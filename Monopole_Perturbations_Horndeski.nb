Cell[BoxData[
 RowBox[{
  RowBox[{"Ruletstar", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"0", ",", "1"}], "]"}], "[", "func_", "]"}], "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":>", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "[", "func", "]"}], "[", 
        RowBox[{"t", ",", "r"}], "]"}], "+", 
       RowBox[{
        RowBox[{"W", "[", "r", "]"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"1", ",", "0"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "[", "func_", "]"}], "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":>", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"1", ",", "1"}], "]"}], "[", "func", "]"}], "[", 
        RowBox[{"t", ",", "r"}], "]"}], "+", 
       RowBox[{
        RowBox[{"W", "[", "r", "]"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"2", ",", "0"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}]}]}], ",", 
     RowBox[{"(*", 
      RowBox[{"Existing", " ", 
       RowBox[{"(", 
        RowBox[{"0", ",", "2"}], ")"}], " ", "rule"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"0", ",", "2"}], "]"}], "[", "func_", "]"}], "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":>", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"0", ",", "2"}], "]"}], "[", "func", "]"}], "[", 
        RowBox[{"t", ",", "r"}], "]"}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "W", "]"}], "[", "r", 
         "]"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"1", ",", "0"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}], "+", 
       RowBox[{"2", " ", 
        RowBox[{"W", "[", "r", "]"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"1", ",", "1"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"W", "[", "r", "]"}], "^", "2"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"2", ",", "0"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}]}]}], ",", 
     RowBox[{"(*", 
      RowBox[{"NEW", " ", 
       RowBox[{"(", 
        RowBox[{"1", ",", "2"}], ")"}], " ", "rule"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"1", ",", "2"}], "]"}], "[", "func_", "]"}], "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":>", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"Derivative", "[", 
          RowBox[{"1", ",", "2"}], "]"}], "[", "func", "]"}], "[", 
        RowBox[{"t", ",", "r"}], "]"}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", "1", "]"}], "[", "W", "]"}], "[", "r", 
         "]"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"2", ",", "0"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}], "+", 
       RowBox[{"2", " ", 
        RowBox[{"W", "[", "r", "]"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"2", ",", "1"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}], "+", 
       RowBox[{
        RowBox[{
         RowBox[{"W", "[", "r", "]"}], "^", "2"}], " ", 
        RowBox[{
         RowBox[{
          RowBox[{"Derivative", "[", 
           RowBox[{"3", ",", "0"}], "]"}], "[", "func", "]"}], "[", 
         RowBox[{"t", ",", "r"}], "]"}]}]}]}], ",", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"NEW", " ", 
       RowBox[{"(", 
        RowBox[{"2", ",", "1"}], ")"}], " ", "rule"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"2", ",", "1"}], "]"}], "[", "func_", "]"}], "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], ":>", 
